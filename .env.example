# Copy this to .env.local and fill in real values.
# .env.local is gitignored; .env.example is committed as a template.

# --- Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Telegram (channel auto-publish on Sanity webhook) ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Channel chat id (e.g. -1001234567890), get via getUpdates after adding bot as admin
TELEGRAM_CHANNEL_ID=
# Public links shown in social dots (channel = read-only broadcast, group = discussion)
NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=
NEXT_PUBLIC_TELEGRAM_GROUP_URL=
# Shared secret with Sanity webhook for HMAC signature verification
SANITY_WEBHOOK_SECRET=

# --- Admin dashboard (/admin) ---
# Comma-separated Supabase user UUIDs that may access /admin.
# Find your UUID after logging in: Supabase Studio → Authentication → Users.
ADMIN_USER_IDS=
